{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/api/proses/(.*)\\.php",
      "dest": "/api/proses/$1.php"
    },
    {
      "src": "/api/admin/(.*)\\.php",
      "dest": "/api/admin/$1.php"
    },
    {
      "src": "/api/(.*)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ]
}