{
  "functions": {
    "api/**/*.php": { "runtime": "vercel-php@0.7.1" },
    "login.php": { "runtime": "vercel-php@0.7.1" },
    "register.php": { "runtime": "vercel-php@0.7.1" }
  },
  "routes": [
    { "src": "/api/proses/(.*)\\.php", "dest": "/api/proses/$1.php" },
    { "src": "/api/(.*)\\.php", "dest": "/api/$1.php" },
    { "src": "/login.php", "dest": "/login.php" },
    { "src": "/register.php", "dest": "/register.php" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}