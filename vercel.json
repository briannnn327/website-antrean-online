{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "rewrites": [
    { "source": "/api/proses/:path*.php", "destination": "/api/proses/:path*.php" },
    { "source": "/api/admin/:path*.php", "destination": "/api/admin/:path*.php" },
    { "source": "/login", "destination": "/api/login.php" },
    { "source": "/beranda", "destination": "/api/beranda.php" },
    { "source": "/dashboardAdmin", "destination": "/api/dashboardAdmin.php" },
    { "source": "/api/:path*.php", "destination": "/api/:path*.php" },
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/:path*", "destination": "/api/:path*" }
  ]
}