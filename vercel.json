{
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.7.1"
        }
    },
    "routes": [
        {
            "src": "/api/admin/(.*)\\.php",
            "dest": "/api/admin/$1.php"
        },
        {
            "src": "/api/proses/(.*)\\.php",
            "dest": "/api/proses/$1.php"
        },
        {
            "src": "/api/service/(.*)\\.php",
            "dest": "/api/service/$1.php"
        },
        {
            "src": "/api/(.*)\\.php",
            "dest": "/api/$1.php"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}