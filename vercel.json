"functions": {
  "api/**/*.php": {
    "runtime": "vercel-php@0.7.2"
  }
}
  "routes": [
    {
      "src": "/api/proses/(.*)\\.php",
      "dest": "/api/proses/$1.php"
    },
    {
      "src": "/api/admin/(.*)\\.php",
      "dest": "/api/admin/$1.php"
    },
    {
      "src": "/login",
      "dest": "/api/login.php"
    },
    {
      "src": "/beranda",
      "dest": "/api/beranda.php"
    },
    {
      "src": "/dashboardAdmin",
      "dest": "/api/dashboardAdmin.php"
    },
    {
      "src": "/api/(.*)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/$1"
    }
  ]
}