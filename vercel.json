{
  "functions": {
    "api/pancingan.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/api/proses/(.*)\\.php",
      "dest": "/api/proses/$1.php"
    },
    {
      "src": "/api/(.*)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/login.php",
      "dest": "/login.php",
      "headers": { "Service-Worker-Allowed": "/" }
    },
    {
      "src": "/(.*)\\.php",
      "dest": "/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}